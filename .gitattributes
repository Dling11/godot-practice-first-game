# Keep source and project metadata consistent across platforms.
* text=auto eol=lf

# Godot scenes and resources are text assets in this project.
*.gd text eol=lf
*.godot text eol=lf
*.tres text eol=lf
*.tscn text eol=lf

# Binary game assets must not be normalized.
*.png binary
*.jpg binary
*.jpeg binary
*.webp binary
*.ogg binary
*.wav binary
*.mp3 binary
*.ttf binary
*.otf binary

