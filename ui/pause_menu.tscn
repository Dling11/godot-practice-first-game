mouse_default_cursor_shape = 2
text = "QUIT TO DESKTOP"

[connection signal="pressed" from="Panel/Margin/Content/ResumeButton" to="." method="close_menu"]
[connection signal="pressed" from="Panel/Margin/Content/MusicButton" to="." method="toggle_music"]
[connection signal="pressed" from="Panel/Margin/Content/SfxButton" to="." method="toggle_sfx"]
[connection signal="pressed" from="Panel/Margin/Content/UiAudioButton" to="." method="toggle_ui_audio"]
[connection signal="pressed" from="Panel/Margin/Content/ReturnButton" to="." method="return_to_sanctuary"]
[connection signal="pressed" from="Panel/Margin/Content/QuitButton" to="." method="quit_game"]
